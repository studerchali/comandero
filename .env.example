# Modo de persistencia: local (default) | api
VITE_REPOSITORY_MODE=local

# Sincronización con backend (Fase 5)
# En desarrollo, deja API_URL vacío para usar el proxy de Vite (/api → :3001)
VITE_SYNC_ENABLED=true
VITE_API_URL=
VITE_API_KEY=

# Backend (server/.env o variables del host)
# PORT=3001
# COMANDERO_API_KEY=opcional-clave-secreta